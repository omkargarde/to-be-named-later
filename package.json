{
  "name": "ecommerce",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "db:gen": "npx drizzle-kit generate",
    "db:mig": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "deploy": "bun run build && wrangler deploy",
    "dev": "vite dev --port 3000",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preview": "bun run build && vite preview",
    "serve": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.23.1",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-form-start": "^1.28.3",
    "@tanstack/react-router": "^1.159.5",
    "@tanstack/react-router-ssr-query": "^1.159.5",
    "@tanstack/react-start": "^1.159.5",
    "@tanstack/router-plugin": "^1.159.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "lint-staged": "^16.2.7",
    "lucide-react": "^0.544.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-form-devtools": "^0.2.16",
    "@tanstack/react-router-devtools": "^1.159.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "daisyui": "^5.5.19",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^27.4.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.14.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.63.0"
  },
  "lint-staged": {
    "*": "bun run lint && bun run oxfmt --no-error-on-unmatched-pattern"
  }
}
